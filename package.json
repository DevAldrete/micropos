		"@supabase/ssr": "^0.8.0",
		"@supabase/supabase-js": "^2.93.3",
		"@tailwindcss/vite": "^4.1.18",
		"@types/react": "^19.2.10",
		"@types/react-dom": "^19.2.3",
		"astro": "^5.17.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.563.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
