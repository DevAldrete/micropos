		"@vitest/ui": "^4.0.18",
		"husky": "^9.1.7",
		"jsdom": "^27.4.0",
		"lint-staged": "^16.2.7",
		"supabase": "^2.76.3",
		"tw-animate-css": "^1.4.0",
		"vitest": "^4.0.18"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,astro}": [
			"biome check --write --no-errors-on-unmatched"
