# ────────────────────────────────────────────────
# Turborepo 
# ────────────────────────────────────────────────
.turbo/

# ────────────────────────────────────────────────
# JavaScript / Node / Package managers
# ────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Lockfiles — usually keep them, but some teams ignore them in monorepos
# package-lock.json        # ← uncomment if you want to ignore npm lockfile
# yarn.lock                # ← uncomment if you want to ignore yarn classic lockfile
# pnpm-lock.yaml           # ← most teams keep this one

# ────────────────────────────────────────────────
# Build outputs (very common in monorepo packages)
# ────────────────────────────────────────────────
dist/
build/
.out/
.next/
.nuxt/
.remix/
svelte-kit/
solid/
coverage/
*.tsbuildinfo
tsconfig.tsbuildinfo

# ────────────────────────────────────────────────
# Logs & temporary files
# ────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# ────────────────────────────────────────────────
# Environment & local secrets
# ────────────────────────────────────────────────
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# ────────────────────────────────────────────────
# Editor & OS files
# ────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ────────────────────────────────────────────────
# Optional – depending on your stack
# ────────────────────────────────────────────────
# Playwright / Cypress
test-results/
playwright-report/
blob-report/
# Vercel
.vercel
# Docker
docker-compose.override.yml

# AGENTS.md
.agents/
skills-lock.json
SKILL.md
AGENTS.md
