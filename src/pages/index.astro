---
import { Header } from "@/components/Header";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import {
	Card,
	CardContent,
	CardDescription,
	CardHeader,
	CardTitle,
} from "@/components/ui/card";
import { Separator } from "@/components/ui/separator";
import Layout from "./Layout.astro";
---

<Layout
	title="MicroPOS - El Punto de Venta para tu Negocio"
	description="Sistema de punto de venta moderno, rápido y seguro. Gestiona ventas, inventario y métricas de tu negocio desde cualquier dispositivo."
>
	<Header client:load />

	<main class="min-h-screen">
		<!-- Hero Section -->
		<section class="relative overflow-hidden">
			<!-- Background gradient decoration -->
			<div class="absolute inset-0 -z-10">
				<div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-primary/5 rounded-full blur-3xl"></div>
			</div>

			<div class="container max-w-screen-2xl px-4 md:px-8 py-24 md:py-40">
				<div class="flex flex-col items-center text-center space-y-8">
					<Badge variant="secondary" className="text-sm px-4 py-1">
						Nuevo - Acceso anticipado disponible
					</Badge>

					<h1
						class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight max-w-4xl leading-tight"
					>
						El Punto de Venta para tu Negocio
					</h1>

					<p class="text-lg md:text-xl text-muted-foreground max-w-2xl leading-relaxed">
						Gestiona ventas, inventario y métricas de tu negocio desde cualquier
						dispositivo. Sin complicaciones, sin hojas de cálculo, sin libretas perdidas.
					</p>

					<div class="flex flex-col sm:flex-row gap-4 pt-4">
						<a href="/auth/signup">
							<Button size="lg" className="text-lg px-8 h-12">
								Comenzar Gratis
							</Button>
						</a>
						<a href="#features">
							<Button size="lg" variant="outline" className="text-lg px-8 h-12">
								Conocer más
							</Button>
						</a>
					</div>

					<div class="flex flex-wrap justify-center items-center gap-6 pt-8 text-sm text-muted-foreground">
						<div class="flex items-center gap-2">
							<svg class="size-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<polyline points="20 6 9 17 4 12"></polyline>
							</svg>
							<span>Sin tarjeta de crédito</span>
						</div>
						<Separator orientation="vertical" className="h-5 hidden sm:block" />
						<div class="flex items-center gap-2">
							<svg class="size-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<polyline points="20 6 9 17 4 12"></polyline>
							</svg>
							<span>Configuración en minutos</span>
						</div>
						<Separator orientation="vertical" className="h-5 hidden sm:block" />
						<div class="flex items-center gap-2">
							<svg class="size-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<polyline points="20 6 9 17 4 12"></polyline>
							</svg>
							<span>Funciona en cualquier dispositivo</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Social Proof / Use Cases -->
		<section class="border-y border-border/40 bg-muted/30 py-12">
			<div class="container max-w-screen-2xl px-4 md:px-8">
				<p class="text-center text-sm font-medium text-muted-foreground mb-8">
					IDEAL PARA TODO TIPO DE NEGOCIOS
				</p>
				<div class="flex flex-wrap justify-center gap-8 md:gap-16 text-muted-foreground">
					<div class="flex items-center gap-2 text-sm font-medium">
						<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
							<polyline points="9 22 9 12 15 12 15 22"></polyline>
						</svg>
						Tiendas locales
					</div>
					<div class="flex items-center gap-2 text-sm font-medium">
						<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="M18 8h1a4 4 0 0 1 0 8h-1"></path>
							<path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
							<line x1="6" y1="1" x2="6" y2="4"></line>
							<line x1="10" y1="1" x2="10" y2="4"></line>
							<line x1="14" y1="1" x2="14" y2="4"></line>
						</svg>
						Cafeterías
					</div>
					<div class="flex items-center gap-2 text-sm font-medium">
						<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="9" cy="21" r="1"></circle>
							<circle cx="20" cy="21" r="1"></circle>
							<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
						</svg>
						Emprendimientos
					</div>
					<div class="flex items-center gap-2 text-sm font-medium">
						<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
							<circle cx="9" cy="7" r="4"></circle>
							<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
							<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
						</svg>
						Clubes y organizaciones
					</div>
					<div class="flex items-center gap-2 text-sm font-medium">
						<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
							<path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
						</svg>
						Negocios personales
					</div>
				</div>
			</div>
		</section>

		<!-- Features Section -->
		<section id="features" class="py-20 md:py-32">
			<div class="container max-w-screen-2xl px-4 md:px-8">
				<div class="text-center space-y-4 mb-16">
					<Badge variant="outline" className="text-sm px-4 py-1">Características</Badge>
					<h2 class="text-3xl md:text-5xl font-bold">
						Todo lo que necesitas para vender
					</h2>
					<p class="text-lg text-muted-foreground max-w-2xl mx-auto">
						Herramientas esenciales diseñadas para que te enfoques en lo que importa: tu negocio
					</p>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
					<Card className="group hover:border-primary/50 transition-colors">
						<CardHeader>
							<div class="size-12 rounded-lg bg-primary/10 flex items-center justify-center mb-2 group-hover:bg-primary/20 transition-colors">
								<svg class="size-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
									<line x1="1" y1="10" x2="23" y2="10"></line>
								</svg>
							</div>
							<CardTitle>Terminal de Venta</CardTitle>
							<CardDescription>
								Interfaz rápida y optimizada para cobrar desde cualquier dispositivo. Agrega productos, aplica descuentos y procesa pagos al instante.
							</CardDescription>
						</CardHeader>
					</Card>

					<Card className="group hover:border-primary/50 transition-colors">
						<CardHeader>
							<div class="size-12 rounded-lg bg-primary/10 flex items-center justify-center mb-2 group-hover:bg-primary/20 transition-colors">
								<svg class="size-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
									<polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
									<line x1="12" y1="22.08" x2="12" y2="12"></line>
								</svg>
							</div>
							<CardTitle>Gestión de Inventario</CardTitle>
							<CardDescription>
								Control de stock en tiempo real. Altas y bajas automáticas con cada venta, alertas de stock bajo y reportes de productos.
							</CardDescription>
						</CardHeader>
					</Card>

					<Card className="group hover:border-primary/50 transition-colors">
						<CardHeader>
							<div class="size-12 rounded-lg bg-primary/10 flex items-center justify-center mb-2 group-hover:bg-primary/20 transition-colors">
								<svg class="size-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<line x1="18" y1="20" x2="18" y2="10"></line>
									<line x1="12" y1="20" x2="12" y2="4"></line>
									<line x1="6" y1="20" x2="6" y2="14"></line>
								</svg>
							</div>
							<CardTitle>Dashboard y Métricas</CardTitle>
							<CardDescription>
								Visualiza el rendimiento de tu negocio con gráficas claras de ingresos diarios, semanales y mensuales. Toma decisiones con datos.
							</CardDescription>
						</CardHeader>
					</Card>

					<Card className="group hover:border-primary/50 transition-colors">
						<CardHeader>
							<div class="size-12 rounded-lg bg-primary/10 flex items-center justify-center mb-2 group-hover:bg-primary/20 transition-colors">
								<svg class="size-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
									<circle cx="9" cy="7" r="4"></circle>
									<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
									<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
								</svg>
							</div>
							<CardTitle>Multi-usuario</CardTitle>
							<CardDescription>
								Invita a tu equipo con roles diferenciados. Cada miembro tiene acceso controlado según sus responsabilidades en el negocio.
							</CardDescription>
						</CardHeader>
					</Card>

					<Card className="group hover:border-primary/50 transition-colors">
						<CardHeader>
							<div class="size-12 rounded-lg bg-primary/10 flex items-center justify-center mb-2 group-hover:bg-primary/20 transition-colors">
								<svg class="size-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
									<polyline points="14 2 14 8 20 8"></polyline>
									<line x1="16" y1="13" x2="8" y2="13"></line>
									<line x1="16" y1="17" x2="8" y2="17"></line>
									<polyline points="10 9 9 9 8 9"></polyline>
								</svg>
							</div>
							<CardTitle>Tickets Digitales</CardTitle>
							<CardDescription>
								Genera comprobantes de venta digitales automáticamente. Compártelos por correo o muéstralos en pantalla para tus clientes.
							</CardDescription>
						</CardHeader>
					</Card>

					<Card className="group hover:border-primary/50 transition-colors">
						<CardHeader>
							<div class="size-12 rounded-lg bg-primary/10 flex items-center justify-center mb-2 group-hover:bg-primary/20 transition-colors">
								<svg class="size-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
									<line x1="12" y1="18" x2="12.01" y2="18"></line>
								</svg>
							</div>
							<CardTitle>Diseño Responsivo</CardTitle>
							<CardDescription>
								Funciona perfectamente en cualquier dispositivo. Vende desde tu celular, tablet o computadora sin perder funcionalidad.
							</CardDescription>
						</CardHeader>
					</Card>
				</div>
			</div>
		</section>

		<!-- How it works -->
		<section class="bg-muted/30 border-y border-border/40 py-20 md:py-32">
			<div class="container max-w-screen-2xl px-4 md:px-8">
				<div class="text-center space-y-4 mb-16">
					<Badge variant="outline" className="text-sm px-4 py-1">Cómo funciona</Badge>
					<h2 class="text-3xl md:text-5xl font-bold">
						Empieza a vender en 3 pasos
					</h2>
				</div>

				<div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
					<div class="text-center space-y-4">
						<div class="size-14 rounded-full bg-primary text-primary-foreground flex items-center justify-center text-xl font-bold mx-auto">
							1
						</div>
						<h3 class="text-xl font-semibold">Crea tu cuenta</h3>
						<p class="text-muted-foreground">
							Regístrate con tu correo o con Google en segundos. Sin formularios largos ni tarjeta de crédito.
						</p>
					</div>

					<div class="text-center space-y-4">
						<div class="size-14 rounded-full bg-primary text-primary-foreground flex items-center justify-center text-xl font-bold mx-auto">
							2
						</div>
						<h3 class="text-xl font-semibold">Agrega tus productos</h3>
						<p class="text-muted-foreground">
							Configura tu catálogo con precios, stock e imágenes. Todo desde un panel intuitivo.
						</p>
					</div>

					<div class="text-center space-y-4">
						<div class="size-14 rounded-full bg-primary text-primary-foreground flex items-center justify-center text-xl font-bold mx-auto">
							3
						</div>
						<h3 class="text-xl font-semibold">Comienza a vender</h3>
						<p class="text-muted-foreground">
							Usa el terminal de venta para procesar ventas y mira tus métricas crecer en tiempo real.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Pricing Section -->
		<section id="pricing" class="py-20 md:py-32">
			<div class="container max-w-screen-2xl px-4 md:px-8">
				<div class="text-center space-y-4 mb-16">
					<Badge variant="outline" className="text-sm px-4 py-1">Precios</Badge>
					<h2 class="text-3xl md:text-5xl font-bold">
						Simple y transparente
					</h2>
					<p class="text-lg text-muted-foreground max-w-2xl mx-auto">
						Empieza gratis y escala cuando lo necesites
					</p>
				</div>

				<div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">
					<Card className="relative">
						<CardHeader>
							<CardTitle className="text-xl">Gratis</CardTitle>
							<CardDescription>Perfecto para empezar</CardDescription>
							<div class="pt-4">
								<span class="text-4xl font-bold">$0</span>
								<span class="text-muted-foreground"> / mes</span>
							</div>
						</CardHeader>
						<CardContent className="space-y-4">
							<ul class="space-y-3 text-sm">
								<li class="flex items-center gap-2">
									<svg class="size-4 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="20 6 9 17 4 12"></polyline>
									</svg>
									1 organización
								</li>
								<li class="flex items-center gap-2">
									<svg class="size-4 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="20 6 9 17 4 12"></polyline>
									</svg>
									Hasta 50 productos
								</li>
								<li class="flex items-center gap-2">
									<svg class="size-4 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="20 6 9 17 4 12"></polyline>
									</svg>
									Terminal de venta
								</li>
								<li class="flex items-center gap-2">
									<svg class="size-4 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="20 6 9 17 4 12"></polyline>
									</svg>
									Dashboard básico
								</li>
							</ul>
						<a href="/auth/signup" class="block pt-4">
							<Button variant="outline" size="lg" className="w-full">
								Comenzar Gratis
							</Button>
						</a>
						</CardContent>
					</Card>

					<Card className="relative border-2 border-primary">
						<div class="absolute -top-3 left-1/2 -translate-x-1/2">
							<Badge className="px-4 py-1">Popular</Badge>
						</div>
						<CardHeader>
							<CardTitle className="text-xl">Pro</CardTitle>
							<CardDescription>Para negocios en crecimiento</CardDescription>
							<div class="pt-4">
								<span class="text-4xl font-bold">$99</span>
								<span class="text-muted-foreground"> MXN / mes</span>
							</div>
						</CardHeader>
						<CardContent className="space-y-4">
							<ul class="space-y-3 text-sm">
								<li class="flex items-center gap-2">
									<svg class="size-4 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="20 6 9 17 4 12"></polyline>
									</svg>
									Organizaciones ilimitadas
								</li>
								<li class="flex items-center gap-2">
									<svg class="size-4 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="20 6 9 17 4 12"></polyline>
									</svg>
									Productos ilimitados
								</li>
								<li class="flex items-center gap-2">
									<svg class="size-4 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="20 6 9 17 4 12"></polyline>
									</svg>
									Métricas avanzadas
								</li>
								<li class="flex items-center gap-2">
									<svg class="size-4 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="20 6 9 17 4 12"></polyline>
									</svg>
									Soporte prioritario
								</li>
								<li class="flex items-center gap-2">
									<svg class="size-4 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="20 6 9 17 4 12"></polyline>
									</svg>
									Exportación de datos
								</li>
							</ul>
						<a href="/auth/signup" class="block pt-4">
							<Button size="lg" className="w-full">
								Comenzar Prueba Gratis
							</Button>
						</a>
						</CardContent>
					</Card>
				</div>
			</div>
		</section>

		<!-- About/Mission Section -->
		<section id="about" class="bg-muted/30 border-y border-border/40 py-20 md:py-32">
			<div class="container max-w-screen-2xl px-4 md:px-8">
				<div class="max-w-3xl mx-auto text-center space-y-6">
					<Badge variant="outline" className="text-sm px-4 py-1">Nuestra Misión</Badge>
					<h2 class="text-3xl md:text-5xl font-bold">
						Simplificar la gestión de tu negocio
					</h2>
					<p class="text-lg text-muted-foreground leading-relaxed">
						MicroPOS nace de la necesidad real de pequeños negocios y emprendedores
						que buscan una herramienta profesional sin la complejidad de los sistemas
						tradicionales. Creemos que gestionar ventas e inventario debería ser tan
						simple como usar tu celular.
					</p>
					<div class="flex flex-wrap justify-center gap-4 pt-4">
						<Badge variant="secondary" className="text-sm px-4 py-2">
							Open Source
						</Badge>
						<Badge variant="secondary" className="text-sm px-4 py-2">
							Hecho en México
						</Badge>
						<Badge variant="secondary" className="text-sm px-4 py-2">
							MIT License
						</Badge>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-20 md:py-32">
			<div class="container max-w-screen-2xl px-4 md:px-8">
				<Card className="border-2 overflow-hidden relative">
					<div class="absolute inset-0 -z-10">
						<div class="absolute top-0 right-0 w-[400px] h-[400px] bg-primary/5 rounded-full blur-3xl"></div>
						<div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-primary/5 rounded-full blur-3xl"></div>
					</div>
					<CardContent className="py-16">
						<div class="text-center space-y-6 max-w-2xl mx-auto">
							<h2 class="text-3xl md:text-4xl font-bold">
								Lleva tu negocio al siguiente nivel
							</h2>
							<p class="text-lg text-muted-foreground">
								Únete a los negocios que ya simplifican su día a día con MicroPOS.
								Empieza gratis, sin compromisos.
							</p>
							<div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
							<a href="/auth/signup">
								<Button size="lg" className="text-lg px-8 h-12">
									Comenzar Ahora
								</Button>
							</a>
							</div>
						</div>
					</CardContent>
				</Card>
			</div>
		</section>
	</main>

	<!-- Footer -->
