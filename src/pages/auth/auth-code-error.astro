---
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import {
	Card,
	CardContent,
	CardDescription,
	CardHeader,
	CardTitle,
} from "@/components/ui/card";
import Layout from "@/pages/Layout.astro";
---

<Layout title="Error de Autenticación - MicroPOS" description="Hubo un error al iniciar sesión.">
	<div class="min-h-screen flex items-center justify-center bg-background px-4">
		<div class="w-full max-w-md space-y-6">
			<Card className="border-2 border-destructive/20">
				<CardHeader className="text-center">
					<div class="flex justify-center mb-2">
						<Badge variant="destructive" className="text-base px-4 py-1">Error</Badge>
					</div>
					<CardTitle className="text-2xl">Error de Autenticación</CardTitle>
					<CardDescription>
						No pudimos completar el inicio de sesión. Esto puede suceder si el enlace expiró o si hubo un problema con el proveedor de autenticación.
					</CardDescription>
				</CardHeader>
				<CardContent className="space-y-4">
					<div class="flex flex-col gap-3">
						<a href="/auth/signin">
							<Button variant="default" size="lg" className="w-full">
								Intentar de nuevo
							</Button>
						</a>
						<a href="/">
							<Button variant="outline" size="lg" className="w-full">
								Volver al inicio
							</Button>
						</a>
					</div>
				</CardContent>
			</Card>
		</div>
	</div>
</Layout>
