TZ=UTC
PORT=3333
# Use 0.0.0.0 inside Docker, 127.0.0.1 for local dev to avoid Node 18+ IPv6 fetch issues
HOST=127.0.0.1
LOG_LEVEL=info
# Generate with: node ace generate:key
APP_KEY=
NODE_ENV=development
# Use "db" as DB_HOST when running inside Docker Compose
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_DATABASE=postgres
SESSION_DRIVER=cookie